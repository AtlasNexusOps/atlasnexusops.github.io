{
  "name": "atlasnexus-site",
  "version": "1.0.0",
  "private": true,
  "description": "Atlas Nexus — Conseil, Opérations & IA Agentique",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./styles.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./styles.css --watch",
    "build:og": "node scripts/build-og.mjs",
    "build": "npm run build:css && npm run build:og",
    "serve": "npx http-server -p 4000 -c-1 ."
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17",
    "sharp": "^0.34.4"
  }
}
